# =============================================================================
# Collins - Research Supervision System (Nigerian Army University Biu)
# Copy this file to .env and fill in your values for local testing.
# =============================================================================

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Collins | NAUB Research Supervision"
INSTITUTION_NAME="Nigerian Army University Biu"

# Database
# Use local Postgres for development/testing and keep your production DB URL only in your host/provider env settings.
# Local Docker example: postgresql://postgres:postgres@localhost:5432/collins_dev?schema=public
# Neon example: postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/collins_dev?schema=public"

# Auth.js / NextAuth v5
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-secret"
AUTH_URL=http://localhost:3000
# Optional alias used by some NextAuth setups
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET="replace-with-a-long-random-secret"

# Pusher (real-time chat + live notifications)
NEXT_PUBLIC_PUSHER_KEY="your-pusher-key"
NEXT_PUBLIC_PUSHER_CLUSTER="mt1"
PUSHER_APP_ID="your-pusher-app-id"
PUSHER_KEY="your-pusher-key"
PUSHER_SECRET="your-pusher-secret"
PUSHER_CLUSTER="mt1"

# UploadThing (file uploads: PDF / DOCX, max 10MB)
UPLOADTHING_TOKEN="your-uploadthing-token"
# Legacy style (if your dashboard still shows these):
# UPLOADTHING_APP_ID=
# UPLOADTHING_SECRET=

# Resend (transactional email)
RESEND_API_KEY="re_xxxxxxxx"
EMAIL_FROM="Collins NAUB <onboarding@resend.dev>"

# Inngest (background jobs: deadline reminders, digests)
INNGEST_EVENT_KEY="your-inngest-event-key"
INNGEST_SIGNING_KEY="your-inngest-signing-key"

# Bootstrap coordinator
# If these are set, `npm run db:seed` will create or update this coordinator account.
BOOTSTRAP_COORDINATOR_EMAIL=""
BOOTSTRAP_COORDINATOR_PASSWORD=""
BOOTSTRAP_COORDINATOR_FIRST_NAME="Admin"
BOOTSTRAP_COORDINATOR_LAST_NAME="User"
BOOTSTRAP_COORDINATOR_DEPARTMENT="Administration"
